# ============================================================
# UTraffic-ML .gitignore
# Goal:
# - Keep source code, scripts, configs, README
# - Ignore raw datasets, generated outputs, model results, caches, virtual envs
# ============================================================


# ============================================================
# 1. Python cache / compiled files
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so


# ============================================================
# 2. Virtual environments
# ============================================================
.venv/
.venv*/
venv/
env/
ENV/
.env/
env.bak/
venv.bak/


# ============================================================
# 3. Environment variables / secrets
# ============================================================
.env
.env.*
!.env.example
.envrc
*.pem
*.key
*.crt
*.p12
*.pfx


# ============================================================
# 4. IDE / editor files
# ============================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db


# ============================================================
# 5. Project-level caches / logs
# ============================================================
cache/
logs/
*.log
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/


# ============================================================
# 6. Raw datasets and downloaded data
# ============================================================
dataset/
datasets/
data/
ml_core/data/
ml_core/src/data_processing/data/


# ============================================================
# 7. Data processing outputs
# ============================================================
ml_core/src/data_processing/outputs/
ml_core/src/data_processing/**/outputs/
ml_core/src/data_processing/**/osm_cache/
ml_core/src/data_processing/**/osm_graph/
ml_core/src/data_processing/**/graph_structure/
ml_core/src/data_processing/**/model_ready_data/
ml_core/src/data_processing/**/traffic_features/
ml_core/src/data_processing/**/match_summary/
ml_core/src/data_processing/**/analysis_report/


# ============================================================
# 8. Model outputs / experiment results
# ============================================================
ml_core/src/models/**/data/
ml_core/src/models/**/results/
ml_core/src/models/**/checkpoints/
ml_core/src/models/**/runs/
ml_core/src/models/**/outputs/
ml_core/src/models/**/logs/

ml_core/checkpoints/
ml_core/plots/
ml_core/cache/
ml_core/experiments/**/outputs/
ml_core/experiments/**/results/
ml_core/experiments/**/checkpoints/


# ============================================================
# 9. Heavy ML / data files
# ============================================================
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

*.npy
*.npz
*.pkl
*.pickle
*.joblib
*.parquet
*.feather
*.h5
*.hdf5
*.pt
*.pth
*.ckpt
*.onnx
*.bin
*.safetensors
*.dat
*.memmap
*.sqlite
*.db
*.csv.gz
*.jsonl
*.graphml


# ============================================================
# 10. Keep code/config/docs even inside ignored-looking folders
# ============================================================
!ml_core/src/models/ML_BranchA/
!ml_core/src/models/ML_BranchA/scripts/
!ml_core/src/models/ML_BranchA/scripts/*.py
!ml_core/src/models/ML_BranchA/README.md
!ml_core/src/models/ML_BranchA/__init__.py

!ml_core/src/data_processing/*.py
!ml_core/src/data_processing/README.md
!ml_core/notebooks/
!ml_core/notebooks/*.ipynb


# ============================================================
# 11. Build / packaging
# ============================================================
build/
dist/
.eggs/
*.egg-info/
*.egg
pip-log.txt
pip-delete-this-directory.txt


# ============================================================
# 12. Test / coverage
# ============================================================
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
*.cover
*.py.cover
.hypothesis/


# ============================================================
# 13. OS / temporary files
# ============================================================
*.tmp
*.temp
*.bak
*.backup
~$*
